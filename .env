SITE_NAME_HEADER=Abdi-Blogs
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://www.abdi.live
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows obsidian-app is-focused show-inline-title show-ribbon show-view-header css-settings-manager fas-hue
USE_FULL_RESOLUTION_IMAGES=true
THEME=https://raw.githubusercontent.com/learnerfvs/Sparkling-Wisdom-obsidian-theme-/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=true
dgShowLocalGraph=false
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true